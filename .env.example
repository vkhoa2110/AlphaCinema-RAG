# OpenAI is required for answer generation/context rewrite
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_GENERATION_MODEL=gpt-4o-mini
GENERATION_MODEL=gpt-4o-mini

# Dense embeddings for index build/retrieval
EMBEDDING_MODEL=text-embedding-3-small
OUTPUT_DIMENSIONALITY=768

# Firestore
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json
FIRESTORE_COLLECTION=movies
MOVIES_SNAPSHOT_PATH=./data/firebase_movies_snapshot.json

# Paths
DATA_DIR=./data
INDEX_PATH=./storage/alpha_cinema_index.json
